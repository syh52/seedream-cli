rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Entries collection: unified images + tasks
    match /entries/{entryId} {
      // Any authenticated user can read (single-user app)
      allow read: if request.auth != null;

      // Create: authenticated + userId matches + status must be 'active'
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'active';

      // Update/delete: any authenticated user (single-user app)
      allow update, delete: if request.auth != null;
    }

    // Legacy: images collection (read-only during transition)
    match /images/{docId} {
      allow read: if true;
    }

    // Legacy: tasks collection (read-only during transition)
    match /tasks/{taskId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
